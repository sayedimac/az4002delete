@page "/"
@inject ChatService ChatService

<PageTitle>Copilot Chat</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex align-items-center gap-2">
                    <span class="fs-5 fw-semibold">💬 Copilot Chat</span>
                </div>
                <div class="card-body chat-window p-3" id="chat-window">
                    @if (!messages.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <p class="mb-1">👋 Welcome! Type your name below to get started.</p>
                        </div>
                    }
                    @foreach (var msg in messages)
                    {
                        <div class="d-flex @(msg.IsUser ? "justify-content-end" : "justify-content-start") mb-2">
                            <div class="message-bubble @(msg.IsUser ? "user-bubble" : "bot-bubble")">
                                @msg.Text
                            </div>
                        </div>
                    }
                    @if (isLoading)
                    {
                        <div class="d-flex justify-content-start mb-2">
                            <div class="message-bubble bot-bubble">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                Thinking…
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-light">
                    <div class="input-group">
                        <input @bind="userInput"
                               @bind:event="oninput"
                               @onkeydown="OnKeyDown"
                               class="form-control"
                               placeholder="Enter your name…"
                               disabled="@isLoading"
                               id="chat-input" />
                        <button class="btn btn-primary"
                                @onclick="SendMessage"
                                disabled="@(isLoading || string.IsNullOrWhiteSpace(userInput))">
                            Send
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .chat-window {
        min-height: 350px;
        max-height: 500px;
        overflow-y: auto;
    }
    .message-bubble {
        max-width: 75%;
        padding: 0.5rem 0.9rem;
        border-radius: 1rem;
        font-size: 0.95rem;
        word-break: break-word;
    }
    .user-bubble {
        background-color: #0d6efd;
        color: white;
        border-bottom-right-radius: 0.2rem;
    }
    .bot-bubble {
        background-color: #e9ecef;
        color: #212529;
        border-bottom-left-radius: 0.2rem;
    }
</style>

@code {
    private record ChatMessage(string Text, bool IsUser);

    private List<ChatMessage> messages = [];
    private string userInput = string.Empty;
    private bool isLoading;

    private async Task SendMessage()
    {
        var input = userInput.Trim();
        if (string.IsNullOrWhiteSpace(input)) return;

        messages.Add(new ChatMessage(input, IsUser: true));
        userInput = string.Empty;
        isLoading = true;

        try
        {
            var reply = await ChatService.GreetAsync(input);
            messages.Add(new ChatMessage(reply, IsUser: false));
        }
        catch
        {
            messages.Add(new ChatMessage("⚠️ Could not reach the server. Please try again.", IsUser: false));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage();
    }
}
